      <column caption='Debited Amount' datatype='real' name='[Calculation_638103826374356992]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Transaction Type]=&quot;Debit&quot; THEN [Amount] END)' />
      </column>
      <column caption='CreditDebitRatio' datatype='real' name='[Calculation_638103826375274497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_650488725331918849]/[Calculation_638103826374356992]' />
      </column>
      <column caption='Net Transaction Amount' datatype='real' name='[Calculation_638103826376216578]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_650488725331918849]-[Calculation_638103826374356992]' />
      </column>
      <column caption='Credited Amount' datatype='real' name='[Calculation_650488725331918849]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Transaction Type]=&quot;Credit&quot; Then [Amount] END)' />
      </column>
      <column caption='Total Transactions Amount' datatype='real' name='[Calculation_710442895527391236]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_638103826374356992] + [Calculation_650488725331918849]' />
      </column>
      <column caption='Transaction per day' datatype='integer' name='[Calculation_710442895532711943]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Transaction Date])' />
      </column>
      <column caption='Transaction per week' datatype='datetime' name='[Calculation_710442895533223944]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Transaction Date])' />
      </column>
      <column caption='No. of Transaction' datatype='integer' name='[Calculation_710442895536775179]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Account Number])' />
      </column>
      <column caption='Account Activity Ratio' datatype='real' name='[Calculation_710442895537041420]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Transaction Date])/SUM([Balance])' />
      </column>
      <column caption='Transaction per Month' datatype='datetime' name='[Calculation_710442895539007501]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Transaction Date])' />
      </column>
